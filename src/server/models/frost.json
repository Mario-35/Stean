	id int8 GENERATED ALWAYS AS IDENTITY( INCREMENT BY 1 MINVALUE 1 MAXVALUE 9223372036854775807 START 1 CACHE 1 NO CYCLE) NOT NULL,
	"phenomenonTime" timestamptz NOT NULL,
	"result" jsonb NULL,
	"resultTime" timestamptz NOT NULL,
	"resultQuality" jsonb NULL,
	"validTime" timestamptz DEFAULT CURRENT_TIMESTAMP NOT NULL,
	parameters jsonb NULL,
	datastream_id int8 NULL,
	multidatastream_id int8 NULL,
	featureofinterest_id int8 DEFAULT '1'::bigint NOT NULL,




    "ThingsLocations": { "table": "THINGS_LOCATIONS",
        "columns": {
            "thing_id": "THING_ID",
            "location_id": "LOCATION_ID"
        }
    }

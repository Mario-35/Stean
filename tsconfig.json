{
    "type": "module", 
    "compileOnSave": false,
    "compilerOptions": {
        "esModuleInterop": true,
        "noImplicitAny": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "strict": true,
        "moduleResolution": "nodenext",
        "noUnusedLocals": true,
        "skipLibCheck": true,
        "noUnusedParameters": false,
        "strictPropertyInitialization": false,
        "preserveConstEnums": true,
        "sourceMap": false,
        "typeRoots": [
            "node_modules/@types",
            "./types"
        ],
        "noEmit": false,
        "module": "node16",
    "outDir": "./build",
    "rootDir": "./src/server",
        "target": "es2022",
        "lib": [
            "es2017"
        ]
    },
    "ts-node": {
        "compilerOptions": {
            "module": "nodenext"
        }
    },
    "include": [
        "src/server/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "migrations",
        "scripts",
        "seeds",
        "test",
        "build",
        "builds"
    ]
}